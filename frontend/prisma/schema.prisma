generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EDITOR
}

enum LeadStatus {
  NEW
  READ
  ARCHIVED
}

model User {
  id           String    @id @default(cuid())
  name         String?
  email        String    @unique
  passwordHash String
  role         UserRole  @default(ADMIN)
  sessions     Session[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("session")
}

model SiteSetting {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sitesetting")
}

model MediaFile {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  url          String
  mimeType     String
  size         Int
  createdAt    DateTime @default(now())

  @@map("mediafile")
}

model Lead {
  id        String     @id @default(cuid())
  name      String
  company   String?
  email     String
  interest  String?
  message   String     @db.Text
  source    String?
  status    LeadStatus @default(NEW)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("lead")
}

model Product {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  description      String   @db.Text
  shortDescription String?  @db.Text
  longDescription  String?  @db.LongText
  badge            String?
  tag              String?
  category         String?
  version          String?
  platformType     String?
  platformUrl      String?
  coverImage       String?
  features         Json?
  contentBlocks    Json?
  published        Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([published, sortOrder])
  @@map("product")
}

model Solution {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  badgeText        String?
  shortDescription String?  @db.Text
  description      String   @db.LongText
  icon             String?
  category         String?
  coverImage       String?
  features         Json?
  processSteps     Json?
  published        Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([published, sortOrder])
  @@map("solution")
}

model Project {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  description     String   @db.Text
  longDescription String?  @db.LongText
  category        String?
  client          String?
  year            String?
  liveUrl         String?
  ctaButtonLabel  String?
  ctaButtonUrl    String?
  coverImage      String?
  gallery         Json?
  tags            Json?
  featured        Boolean  @default(false)
  published       Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([published, featured, sortOrder])
  @@map("project")
}

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  summary     String?   @db.Text
  content     Json?
  category    String?
  tags        Json?
  coverImage  String?
  author      String?
  readTime    Int       @default(5)
  featured    Boolean   @default(false)
  published   Boolean   @default(true)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, publishedAt])
  @@map("blogpost")
}

model Template {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  description  String?  @db.Text
  category     String?
  previewImage String?
  coverImage   String?
  demoUrl      String?
  features     Json?
  published    Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([published, sortOrder])
  @@map("template")
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  image     String?
  bio       String?  @db.Text
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, sortOrder])
  @@map("teammember")
}