{
  "kind": "collectionType",
  "collectionName": "projects_v5",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Proje",
    "description": "İşlerimiz / Portföy projeleri"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "project_category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::project-category.project-category"
    },
    "description": {
      "type": "text"
    },
    "cover_image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images"]
    },
    "client": {
      "type": "string"
    },
    "year": {
      "type": "integer"
    },
    "live_url": {
      "type": "string"
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "tags": {
      "type": "json"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}